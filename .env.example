# PostgreSQL connection string (libpq format)
SAVING_DB=host=127.0.0.1 port=5432 dbname=saving user=postgres password=changeme sslmode=disable

# RabbitMQ
AMQP_URL=amqp://admin:admin@127.0.0.1:5672/

# JWT signing secret — change to a long random string in production
JWT_SECRET=change_me_to_a_long_random_secret
