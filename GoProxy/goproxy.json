{
  "server": {
    "address": "127.0.0.1:8087",
    "readTimeout": "60s",
    "writeTimeout": "120s",
    "maxQueue": 1000,
    "workers": 20
  },
  "storage": {
    "type": "filesystem",
    "basePath": "/var/lib/goproxy",
    "mirror": {
      "s3": {
        "endpoint": "https://__OSS_ENDPOINT__",
        "bucket": "__OSS_BUCKET__",
        "region": "__OSS_REGION__",
        "accessKey": "__OSS_ACCESS_KEY__",
        "secretKey": "__OSS_SECRET_KEY__",
        "forcePathStyle": true,
        "disableSSL": false
      }
    }
  },
  "auth": {
    "enabled": false,
    "users": []
  }
}
