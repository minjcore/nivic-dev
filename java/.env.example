# Copy to .env and adjust. Used by ./dev-server.sh (sourced before mvn cargo:run).
# Same keys can be set in src/main/resources/application.properties (env and -D override file).
JDBC_URL=jdbc:postgresql://127.0.0.1:5432/your_database
JDBC_USER=your_user
JDBC_PASSWORD=your_password
# JDBC_POOL_SIZE=10
